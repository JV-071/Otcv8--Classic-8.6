    height: 22
    margin-top: 12

    OptionCheckBox
      id: showTimestampsInConsole
      !text: tr('Show Timestamps in Console')
      anchors.left: parent.left
      anchors.right: parent.right
      anchors.top: parent.top
      margin: 5

  FlatPanel
    height: 22
    margin-top: 12


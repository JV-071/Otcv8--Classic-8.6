    height: 22
    margin-top: 12

    OptionCheckBox
      id: showStatusMessagesInConsole
      !text: tr('Show Status Messages in Console')
      anchors.left: parent.left
      anchors.right: parent.right
      anchors.top: parent.top
      margin: 5

